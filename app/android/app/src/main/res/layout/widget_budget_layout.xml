<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:id="@+id/widget_budget_root" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/widget_budget_background" android:padding="6dp">

    <LinearLayout android:id="@+id/budget_content_group" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:gravity="center" android:orientation="horizontal">

        <LinearLayout android:id="@+id/budget_legend_group" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="6dp" android:layout_weight="1" android:gravity="center_vertical" android:orientation="vertical" android:visibility="gone">

            <LinearLayout android:id="@+id/budget_item_row_0" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal" android:visibility="gone">

                <ImageView android:id="@+id/budget_item_icon_0" android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:scaleType="fitCenter" />

                <TextView android:id="@+id/budget_item_name_0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:text="Budget" android:textColor="@color/budget_widget_value" android:textSize="12sp" />

                <TextView android:id="@+id/budget_item_value_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="0" android:textColor="@color/budget_widget_value" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/budget_item_row_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:gravity="center_vertical" android:orientation="horizontal" android:visibility="gone">

                <ImageView android:id="@+id/budget_item_icon_1" android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:scaleType="fitCenter" />

                <TextView android:id="@+id/budget_item_name_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:text="Budget" android:textColor="@color/budget_widget_value" android:textSize="12sp" />

                <TextView android:id="@+id/budget_item_value_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="0" android:textColor="@color/budget_widget_value" android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout android:id="@+id/budget_item_row_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="3dp" android:gravity="center_vertical" android:orientation="horizontal" android:visibility="gone">

                <ImageView android:id="@+id/budget_item_icon_2" android:layout_width="18dp" android:layout_height="18dp" android:contentDescription="@null" android:scaleType="fitCenter" />

                <TextView android:id="@+id/budget_item_name_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:ellipsize="end" android:maxLines="1" android:text="Budget" android:textColor="@color/budget_widget_value" android:textSize="12sp" />

                <TextView android:id="@+id/budget_item_value_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="0" android:textColor="@color/budget_widget_value" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout android:id="@+id/budget_ring_frame" android:layout_width="76dp" android:layout_height="76dp" android:foregroundGravity="center">

            <ImageView android:id="@+id/budget_ring_image" android:layout_width="match_parent" android:layout_height="match_parent" android:contentDescription="Budget activity rings" android:scaleType="fitCenter" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/budget_empty_group" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:gravity="center" android:orientation="vertical" android:paddingStart="10dp" android:paddingEnd="10dp" android:visibility="gone">

        <TextView android:id="@+id/budget_empty_message" android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="center" android:maxLines="3" android:text="Choose up to 3 budgets in Totals." android:textColor="@color/budget_widget_value" android:textSize="10sp" />
    </LinearLayout>
</FrameLayout>
